# Environment variables (root / docker-compose)
# Copy to .env and fill in values.

# --- Application ---
APP_ENV=development
ENV=development

# --- Backend (referenced by docker-compose) ---
BACKEND_HOST=backend
BACKEND_PORT=8000

# --- Frontend build ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Database (SQLite default) ---
DATABASE_URL=sqlite:///./data/app.db
# PostgreSQL profile:
# DATABASE_URL=postgresql+psycopg2://psal:psal@db:5432/psal

# --- Postgres service (docker profile) ---
POSTGRES_USER=psal
POSTGRES_PASSWORD=change_me
POSTGRES_DB=psal

# --- Auth ---
JWT_SECRET_KEY=change_me_to_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_PUBLIC_REGISTRATION=true

# --- Upload ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=250
LARGE_FILE_WARNING_MB=50
TEMP_ASSETS_DIR=./temp_assets
ASSETS_DIR=./assets
ASSET_MANIFEST_PATH=./data/asset_manifest.enc

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_ANALYSIS_PER_MINUTE=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
SLOW_REQUEST_THRESHOLD_MS=2000

# --- LLM insights (optional) ---
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_MODEL=

# --- Redis (optional Celery) ---
REDIS_URL=redis://redis:6379/0

# --- Seed ---
SEED_ADMIN=false
